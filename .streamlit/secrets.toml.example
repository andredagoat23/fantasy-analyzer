# Copy this file to `.streamlit/secrets.toml` and paste your real values.
# The real secrets.toml is gitignored — never commit it.
# For the deployed app, paste the same into Streamlit Cloud → app → Settings → Secrets.

ANTHROPIC_API_KEY = "sk-ant-..."

# --- Login gate --------------------------------------------------------------
# The app requires a login. Two ways to configure it:
#
# (A) SIMPLE PASSWORD (works instantly, no external setup):
#     Uncomment the line below and set any passphrase. Anyone with it can enter.
# app_password = "choose-a-passphrase"
#
# (B) GOOGLE SIGN-IN (real accounts — overrides the password if the [auth]
#     block below is present). Set this up in Google Cloud, then fill in [auth].
#     Steps:
#       1. console.cloud.google.com → new project.
#       2. APIs & Services → OAuth consent screen → External → add your email.
#       3. Credentials → Create credentials → OAuth client ID → Web application.
#       4. Authorized redirect URIs — add BOTH:
#            http://localhost:8501/oauth2callback
#            https://<your-app>.streamlit.app/oauth2callback
#       5. Copy the client ID + secret into [auth] below.
#       6. cookie_secret: any long random string you make up.
#     (You paste these values yourself — they never go through chat.)
#
# [auth]
# redirect_uri = "http://localhost:8501/oauth2callback"   # use your .streamlit.app URL on Cloud
# cookie_secret = "a-long-random-string-you-make-up"
# client_id = "....apps.googleusercontent.com"
# client_secret = "GOCSPX-..."
# server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"
#
# (C) EMAIL ALLOW-LIST (with Google sign-in): only these emails can get in — no password
#     needed. Leave it out to let ANY signed-in Google account through. Add/remove people by
#     editing this line (local + Cloud secrets). Case-insensitive.
# allowed_emails = ["you@gmail.com", "mom@gmail.com", "buddy@icloud.com"]

# --- Live browser bridge (RECOMMENDED live source; works on any draft site) ---
# A tiny browser userscript on the draft site posts each pick to a Firebase Realtime
# Database "mailbox"; the app polls it every few seconds. Because picks come from the
# browser, this works LIVE on ESPN / Sleeper / Yahoo. Takes precedence over [espn].
#   url = your Firebase Realtime Database URL (e.g. https://<project>-default-rtdb.firebaseio.com)
# (For local dev you can instead set the FA_BRIDGE_URL environment variable.)
# [bridge]
# url = "https://your-project-default-rtdb.firebaseio.com"

# --- Live ESPN draft sync (fallback; only reflects picks AFTER the draft finalizes) --
# league_id is in your ESPN league URL (…/leagues/<league_id>). espn_s2 + swid are
# browser cookies for fantasy.espn.com (needed for private leagues; skip for public).
[espn]
league_id = "123456"
year = 2026
espn_s2 = "AEB..."
swid = "{XXXXXXXX-XXXX-...}"
