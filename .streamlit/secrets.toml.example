# Copy this file to `.streamlit/secrets.toml` and paste your real values.
# The real secrets.toml is gitignored — never commit it.
# For the deployed app, paste the same into Streamlit Cloud → app → Settings → Secrets.
ANTHROPIC_API_KEY = "sk-ant-..."

# --- Live ESPN draft sync (optional; leave out to use manual tracking) ---
# league_id is in your ESPN league URL (…/leagues/<league_id>). espn_s2 + swid are
# browser cookies for fantasy.espn.com (needed for private leagues; skip for public).
[espn]
league_id = "123456"
year = 2026
espn_s2 = "AEB..."
swid = "{XXXXXXXX-XXXX-...}"
